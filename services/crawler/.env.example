# MinIO connection
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=crawled-pages
MINIO_CLEANED_BUCKET=crawled-pages-cleaned
MINIO_SECURE=false

# Crawler settings
CRAWL_SEED_URL=https://website.cs.vt.edu
CRAWL_MAX_DEPTH=2
CRAWL_MAX_PAGES=500

# Comma-separated domains to crawl (only website.cs.vt.edu — the scrapable site)
CRAWL_ALLOWED_DOMAINS=website.cs.vt.edu

# Comma-separated domains to never follow (auth-gated, irrelevant, or out of scope)
CRAWL_BLOCKED_DOMAINS=git.cs.vt.edu,gitlab.cs.vt.edu,mail.cs.vt.edu,webmail.cs.vt.edu,portal.cs.vt.edu,api.cs.vt.edu,forum.cs.vt.edu,login.cs.vt.edu,students.cs.vt.edu,wordpress.cs.vt.edu,wiki.cs.vt.edu

# PruningContentFilter threshold — higher = more aggressive boilerplate removal (0.0-1.0)
CRAWL_PRUNE_THRESHOLD=0.45
